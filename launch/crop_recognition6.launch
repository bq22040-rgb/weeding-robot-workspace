<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <!-- ==========================
       1. 雑草除去統合ノード
       ========================== -->
  <node name="weeding_recognition"
        pkg="crop_recognition2"
        type="weeding_recognition_node_3cam_hungarian_fallback.py"
        output="screen" />

  <!-- ==========================
       2. 俯瞰カメラ認識ノード
       camera1
       ========================== -->
  <node name="top_recognition"
        pkg="crop_recognition2"
        type="top_recognition_node.py"
        output="screen">
    <param name="act_mask_enable" value="true"/>
    <param name="act_mask_rate" value="5.0"/>
  </node>

  <!-- ==========================
       3. 横カメラ認識ノード
       camera2
       ========================== -->
  <node name="side_recognition"
        pkg="crop_recognition2"
        type="side_recognition_node.py"
        output="screen">
    <param name="act_mask_enable" value="true"/>
    <param name="act_mask_rate" value="5.0"/>
  </node>

  <!-- ==========================
       4. 第3カメラ認識ノード
       camera3
       ========================== -->
  <node name="third_recognition"
        pkg="crop_recognition2"
        type="third_recognition_node.py"
        output="screen">
    <param name="act_mask_enable" value="true"/>
    <param name="act_mask_rate" value="5.0"/>
  </node>

  <!-- ==========================
       5. RealSense カメラ 1（俯瞰）
       ========================== -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="camera1"/>
    <arg name="device_type" value="d435"/>
    <arg name="serial_no" value="335522071461"/>
    <arg name="initial_reset" value="false"/>

    <arg name="enable_sync" value="false"/>
    <arg name="align_depth" value="true"/>
    <arg name="enable_color" value="true"/>
    <arg name="enable_depth" value="true"/>
    <arg name="filters" value="pointcloud"/>

    <!-- D435iのIMUを使わない -->
    <arg name="enable_gyro" value="false"/>
    <arg name="enable_accel" value="false"/>
    <arg name="unite_imu_method" value="none"/>

    <arg name="enable_confidence" value="false"/>

    <arg name="depth_width"  value="640"/>
    <arg name="depth_height" value="480"/>
    <arg name="depth_fps"    value="15"/>

    <arg name="color_width"  value="1280"/>
    <arg name="color_height" value="720"/>
    <arg name="color_fps"    value="15"/>

    <arg name="wait_for_device_timeout" value="30.0"/>
  </include>

  <!-- ==========================
       6. RealSense カメラ 2（横）
       ========================== -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="camera2"/>
    <arg name="device_type" value="d435"/>
    <arg name="serial_no" value="243122074621"/>
    <arg name="initial_reset" value="false"/>

    <arg name="enable_sync" value="false"/>
    <arg name="align_depth" value="true"/>
    <arg name="enable_color" value="true"/>
    <arg name="enable_depth" value="true"/>
    <arg name="filters" value="pointcloud"/>

    <!-- D435iのIMUを使わない -->
    <arg name="enable_gyro" value="false"/>
    <arg name="enable_accel" value="false"/>
    <arg name="unite_imu_method" value="none"/>

    <arg name="enable_confidence" value="false"/>

    <arg name="depth_width"  value="640"/>
    <arg name="depth_height" value="480"/>
    <arg name="depth_fps"    value="15"/>

    <arg name="color_width"  value="1280"/>
    <arg name="color_height" value="720"/>
    <arg name="color_fps"    value="15"/>

    <arg name="wait_for_device_timeout" value="30.0"/>
  </include>

  <!-- ==========================
       7. RealSense カメラ 3（追加カメラ）
       ※ serial_no は実機の値に変更する
       ========================== -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="camera3"/>
    <arg name="device_type" value="d435"/>

    <!-- ここを3台目のRealSenseのシリアル番号に変更 -->
    <arg name="serial_no" value="335222076890"/>

    <arg name="initial_reset" value="false"/>

    <arg name="enable_sync" value="false"/>
    <arg name="align_depth" value="true"/>
    <arg name="enable_color" value="true"/>
    <arg name="enable_depth" value="true"/>
    <arg name="filters" value="pointcloud"/>

    <!-- D435iのIMUを使わない -->
    <arg name="enable_gyro" value="false"/>
    <arg name="enable_accel" value="false"/>
    <arg name="unite_imu_method" value="none"/>

    <arg name="enable_confidence" value="false"/>

    <arg name="depth_width"  value="640"/>
    <arg name="depth_height" value="480"/>
    <arg name="depth_fps"    value="15"/>

    <arg name="color_width"  value="1280"/>
    <arg name="color_height" value="720"/>
    <arg name="color_fps"    value="15"/>

    <arg name="wait_for_device_timeout" value="30.0"/>
  </include>

  <!-- ==========================
       8. カメラ ↔ base_link の TF
       ========================== -->

  <!-- camera1：近接俯瞰カメラ -->
  <node pkg="tf2_ros"
        type="static_transform_publisher"
        name="tf2_base_to_cam1_link"
        args="0.07 0 0  0 0.7071 0 0.7071  base_link camera1_link" />

  <!-- camera2：横カメラ -->
  <node pkg="tf2_ros"
        type="static_transform_publisher"
        name="tf2_base_to_cam2_link"
        args="0 -0.50 -0.25  0 0 0.7071 0.7071  base_link camera2_link" />

  <!-- camera3：全体俯瞰カメラ -->
  <!-- 
       全体俯瞰
       実際の取り付け位置に合わせて x y z qx qy qz qw を変更する。
  -->
  <node pkg="tf2_ros"
        type="static_transform_publisher"
        name="tf2_base_to_cam3_link"
        args="0.11 0.00 0.38  0 0.7071 0 0.7071  base_link camera3_link" />

  <!-- ==========================
       9. 雑草位置可視化ノード
       ========================== -->
  <node pkg="crop_recognition2"
        type="weed_marker_node.py"
        name="weed_marker_node"
        output="screen"/>

</launch>
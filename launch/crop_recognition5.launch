<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <!-- ==========================
       1. 雑草除去中枢ノード
       ========================== -->
  <!-- ※ weeding_recognition_node.py が「sideのみ」を想定していない場合があるので、
       そのときは node 側に mode パラメータ等を追加する必要があります（後で調整）。 -->
  <node name="weeding_recognition2"
        pkg="crop_recognition2"
        type="weeding_recognition2_node.py"
        output="screen">
    <!-- 任意：もし node が対応しているなら “side_only” 等のモード指定をここに追加 -->
    <!-- <param name="mode" value="side_only" /> -->
  </node>

  <!-- ==========================
       2. 横カメラ認識ノード（sideのみ）
       ========================== -->
  <node name="side_recognition"
        pkg="crop_recognition2"
        type="side_recognition_node.py"
        output="screen" />

  <!-- ==========================
       3. RealSense カメラ（横）camera2
       ========================== -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="camera2"/>
    <arg name="device_type" value="d435"/>
    <arg name="serial_no" value="243122074621"/>
    <arg name="initial_reset" value="false"/>
    <arg name="enable_sync" value="false"/>
    <arg name="align_depth" value="true"/>
    <arg name="enable_color" value="true"/>
    <arg name="enable_depth" value="true"/>
    <arg name="enable_confidence" value="false"/>

    <arg name="depth_width"  value="640"/>
    <arg name="depth_height" value="480"/>
    <arg name="depth_fps"    value="6"/>

    <arg name="color_width"  value="1280"/>
    <arg name="color_height" value="720"/>
    <arg name="color_fps"    value="6"/>

    <arg name="wait_for_device_timeout" value="15.0"/>
  </include>

  <!-- serial_no を “文字列” として上書き（XML-RPC 対策） -->
  <param name="/camera2/realsense2_camera/serial_no"
         value="243122074621" type="str"/>

  <!-- ==========================
       4. TF: base_link → camera2_link
       ========================== -->
  <!-- 注意：static_transform_publisher は
       args="x y z qx qy qz qw parent child"（カンマ無し） -->
  <node pkg="tf2_ros"
        type="static_transform_publisher"
        name="tf2_base_to_cam2_link"
        args="-0.38 0 -0.43  0 0 0 1  base_link camera2_link" />

  <!-- ==========================
       5. RViz可視化（雑草マーカー）
       ========================== -->
  <node pkg="crop_recognition2"
        type="weed_marker_node.py"
        name="weed_marker_node"
        output="screen"/>

</launch>


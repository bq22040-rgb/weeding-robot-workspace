<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <!-- 作物認識ノード -->
  <node name="crop_recognition2_node" pkg="crop_recognition2" type="crop_recognition2_node.py" output="screen"/>

  <!-- RealSense カメラ1 -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="camera1"/>
    <arg name="device_type" value="d435"/>
    <arg name="serial_no" value="335522071461"/>
    <arg name="initial_reset" value="true"/>
    <arg name="enable_sync" value="false"/>
    <arg name="align_depth" value="true"/>
    <arg name="enable_color" value="true"/>
    <arg name="enable_depth" value="true"/>
    <arg name="enable_confidence" value="false"/>

    <!-- 帯域とフォーマットの相性優先 -->
    <arg name="depth_width" value="848"/>
    <arg name="depth_height" value="480"/>
    <arg name="depth_fps" value="15"/>

    <arg name="color_width" value="1280"/>
    <arg name="color_height" value="720"/>
    <arg name="color_fps" value="6"/>

    <arg name="wait_for_device_timeout" value="15.0"/>
  </include>

  <!-- RealSense カメラ2 -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="camera2"/>
    <arg name="device_type" value="d435"/>
    <arg name="serial_no" value="243122074621"/>
    <arg name="initial_reset" value="true"/>
    <arg name="enable_sync" value="false"/>
    <arg name="align_depth" value="true"/>
    <arg name="enable_color" value="true"/>
    <arg name="enable_depth" value="true"/>
    <arg name="enable_confidence" value="false"/>

    <arg name="depth_width" value="848"/>
    <arg name="depth_height" value="480"/>
    <arg name="depth_fps" value="15"/>

    <arg name="color_width" value="1280"/>
    <arg name="color_height" value="720"/>
    <arg name="color_fps" value="6"/>

    <arg name="wait_for_device_timeout" value="15.0"/>
  </include>

  <!-- serial_no を “文字列” として上書き（XML-RPC対策） -->
  <param name="/camera1/realsense2_camera/serial_no" value="335522071461" type="str"/>
  <param name="/camera2/realsense2_camera/serial_no" value="243122074621" type="str"/>
  
  <!-- 元: yaw=-1.5708, pitch=3.1415, roll=0 をクォータニオンに変換 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf2_base_to_cam1_optical"
        args="0 0 -0.2  0.707108 0.707105 -0.000033 0.000033  base_link camera1_color_optical_frame" />

  <!-- 元: yaw=-1.5708, pitch=0, roll=-1.5708 をクォータニオンに変換 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="tf2_base_to_cam2_optical"
        args="-0.25 0 -0.8  -0.500000 0.500002 -0.500000 0.499998  base_link camera2_color_optical_frame" />
       
</launch>

